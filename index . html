<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pankaj Bhardwaj - Stock Market Channel</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: #f4f7fc;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            color: #333;
            padding: 20px 10px;
        }

        /* Container designed to look like a mobile screen/card */
        .landing-card {
            background: #ffffff;
            width: 100%;
            max-width: 450px;
            border-radius: 24px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            padding: 24px;
            text-align: center;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* Top Online Status Badge */
        .status-badge {
            background-color: #f0f5ff;
            color: #2b579a;
            font-size: 14px;
            font-weight: 500;
            padding: 8px 16px;
            border-radius: 20px;
            display: inline-flex;
            align-items: center;
            justify-center: center;
            gap: 8px;
            margin: 0 auto;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            background-color: #4361ee;
            border-radius: 50%;
        }

        /* Profile Section */
        .profile-container {
            position: relative;
            width: 120px;
            height: 120px;
            margin: 0 auto;
        }

        .profile-img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #e2e8f0;
        }

        .verified-badge {
            position: absolute;
            bottom: 5px;
            right: 5px;
            width: 24px;
            height: 24px;
            background-color: #1d4ed8;
            border-radius: 50%;
            border: 2px solid #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 12px;
            font-weight: bold;
        }

        /* Typography */
        .name {
            font-size: 24px;
            font-weight: 700;
            letter-spacing: 0.5px;
            color: #111827;
        }

        .channel-title {
            color: #2563eb;
            font-size: 15px;
            font-weight: 600;
            margin-top: -10px;
        }

        /* Rating Section */
        .rating-container {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            font-size: 14px;
            color: #6b7280;
        }

        .stars {
            color: #f59e0b;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-top: 10px;
        }

        .stat-box {
            background: #f8fafc;
            border: 1px solid #f1f5f9;
            padding: 12px 8px;
            border-radius: 12px;
        }

        .stat-val {
            font-size: 16px;
            font-weight: 700;
            color: #1d4ed8;
        }

        .stat-lbl {
            font-size: 11px;
            color: #64748b;
            margin-top: 4px;
        }

        /* Offer Text */
        .main-heading {
            font-size: 18px;
            font-weight: 700;
            color: #111827;
            line-height: 1.4;
        }

        .sub-heading {
            font-size: 13px;
            color: #6b7280;
            margin-top: -12px;
        }

        /* Alert Notification Bar */
        .alert-bar {
            background-color: #fff7ed;
            border: 1px solid #ffedd5;
            color: #c2410c;
            font-size: 13px;
            font-weight: 500;
            padding: 10px;
            border-radius: 30px;
        }

        /* Buttons */
        .btn-blue {
            background-color: #2563eb;
            color: white;
            font-size: 16px;
            font-weight: 600;
            padding: 16px;
            border-radius: 14px;
            text-decoration: none;
            display: block;
            transition: background 0.2s;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
        }

        .btn-blue:hover {
            background-color: #1d4ed8;
        }

        .btn-dark {
            background-color: #111827;
            color: white;
            font-size: 16px;
            font-weight: 600;
            padding: 16px;
            border-radius: 14px;
            text-decoration: none;
            display: block;
            transition: background 0.2s;
        }

        .btn-dark:hover {
            background-color: #030712;
        }

        /* Features List */
        .features-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
            text-align: left;
        }

        .feature-item {
            background: #f8fafc;
            border: 1px solid #f1f5f9;
            padding: 14px 16px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 14px;
            font-weight: 500;
            color: #334155;
        }

        .feature-icon {
            font-size: 18px;
        }

        /* Footer Info */
        .footer-info {
            font-size: 13px;
            color: #64748b;
            display: flex;
            justify-content: center;
            gap: 8px;
        }

        .time-offer {
            font-size: 12px;
            color: #ef4444;
            font-weight: 500;
            margin-top: -10px;
        }
    </style>
</head>
<body>

    <div class="landing-card">
        <div class="status-badge">
            <span class="status-dot"></span>
            5,947 traders online now
        </div>

        <div>
            <div class="profile-container">
                <img src="https://via.placeholder.com/150" alt="Pankaj Bhardwaj" class="profile-img">
                <div class="verified-badge">✓</div>
            </div>
        </div>

        <div class="name">PANKAJ BHARDWAJ</div>
        <div class="channel-title">🏆 India's No.1 Stock Market Channel</div>

        <div class="rating-container">
            <span class="stars">★★★★★</span>
            <span>4.9/5 (2,340 reviews)</span>
        </div>

        <div class="stats-grid">
            <div class="stat-box">
                <div class="stat-val">50K+</div>
                <div class="stat-lbl">Members</div>
            </div>
            <div class="stat-box">
                <div class="stat-val">5+ Yrs</div>
                <div class="stat-lbl">Experience</div>
            </div>
            <div class="stat-box">
                <div class="stat-val">95%</div>
                <div class="stat-lbl">Accuracy</div>
            </div>
        </div>

        <div class="main-heading">
            Get <span style="color: #2563eb;">FREE daily calls</span> for NIFTY, BANKNIFTY & SENSEX
        </div>
        <div class="sub-heading">
            Join thousands of traders getting free premium analysis daily
        </div>

        <div class="alert-bar">
            🔥 7,589 people joined today — Limited FREE access!
        </div>

        <a href="#" class="btn-blue">Join Free Telegram Channel →</a>

        <div class="features-list">
            <div class="feature-item">
                <span class="feature-icon">📊</span>
                <span>Daily Nifty & BankNifty Levels</span>
            </div>
            <div class="feature-item">
                <span class="feature-icon">🎓</span>
                <span>No Paid Tips – Purely Educational</span>
            </div>
            <div class="feature-item">
                <span class="feature-icon">⏳</span>
                <span>5+ Years of Market Experience</span>
            </div>
            <div class="feature-item">
                <span class="feature-icon">👥</span>
                <span>50,000+ Subscribers Trust Us</span>
            </div>
        </div>

        <div class="footer-info">
            <span>✅ Verified Channel</span>
            <span>•</span>
            <span>Free Forever</span>
            <span>•</span>
            <span>No Spam</span>
        </div>

        <a href="#" class="btn-dark">Join Now — It's 100% FREE</a>
        
        <div class="time-offer">
            ⏰ Limited time offer
        </div>
    </div>

</body>
</html>
