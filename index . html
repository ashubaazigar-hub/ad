<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bank Nifty Expert</title>
    <style>
        :root {
            --bg-top: #0e2920;
            --bg-bottom: #05100c;
            --card-bg: #112c22;
            --card-border: #1d4d35;
            --text-main: #ffffff;
            --text-muted: #9ca3af;
            --accent-green: #34d399;
            --cta-gradient: linear-gradient(90deg, #2dd4bf, #4ade80);
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }
        
        body {
            background-color: #000;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }
        
        .container {
            background: linear-gradient(180deg, var(--bg-top) 0%, var(--bg-bottom) 100%);
            width: 100%;
            max-width: 400px;
            border-radius: 24px;
            padding: 30px 20px;
            text-align: center;
            border: 1px solid #1a3a2a;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }
        
        /* DP (Profile Photo) ka design */
        .profile-pic {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 3px solid var(--accent-green);
            margin-bottom: 15px;
            object-fit: cover;
        }
        
        h1 {
            color: var(--text-main);
            font-size: 24px;
            margin-bottom: 5px;
        }
        
        p {
            color: var(--text-muted);
            margin-bottom: 25px;
            font-size: 15px;
        }
        
        /* Buttons ka design */
        .btn {
            display: block;
            width: 100%;
            padding: 14px;
            margin-bottom: 15px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: bold;
            font-size: 16px;
            transition: transform 0.2s ease;
        }
        
        .btn:hover {
            transform: scale(1.02);
        }
        
        /* Pehla Button */
        .btn-secondary {
            background-color: var(--card-bg);
            color: var(--text-main);
            border: 1px solid var(--card-border);
        }
        
        /* Join Now Button (Niche wala) */
        .btn-primary {
            background: var(--cta-gradient);
            color: #000;
            border: none;
        }
    </style>
</head>
<body>

    <div class="container">
        
        <!-- Yahan aapki DP aayegi -->
        <img src="1000162914.jpg" alt="Bank Nifty Expert" class="profile-pic">

        <!-- Title aur Description -->
        <h1>Bank Nifty Expert</h1>
        <p>Official Telegram Channel</p>

        <!-- Pehla Button -->
        <a href="https://t.me/+qEokwh0D-WlkNzJl" target="_blank" class="btn btn-secondary">
            Telegram Channel
        </a>

        <!-- Dusra Button jisme 'Join Now' likha hai -->
        <a href="https://t.me/+qEokwh0D-WlkNzJl" target="_blank" class="btn btn-primary">
            Join Now
        </a>
        
    </div>

</body>
</html>
