<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Share Market Pro</title>

<!-- Meta Pixel Code yahan paste karna -->

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial,sans-serif;}
body{
background:#0d1117;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
color:#fff;
}
.card{
width:90%;
max-width:380px;
background:#161b22;
padding:25px;
border-radius:18px;
text-align:center;
box-shadow:0 0 20px rgba(255,215,0,.2);
}
img{
width:110px;
height:110px;
border-radius:50%;
border:3px solid gold;
margin-bottom:15px;
}
h1{
color:gold;
font-size:28px;
margin-bottom:8px;
}
p{
color:#ccc;
margin-bottom:15px;
}
.timer{
font-size:38px;
color:#00ff99;
font-weight:bold;
margin:20px 0;
}
.btn{
display:block;
width:100%;
padding:15px;
margin:10px 0;
text-decoration:none;
border-radius:10px;
font-size:18px;
font-weight:bold;
}
.join{
background:#00c853;
color:#fff;
}
.backup{
background:#2962ff;
color:#fff;
}
.footer{
margin-top:15px;
font-size:13px;
color:#888;
}
</style>
</head>

<body>

<div class="card">

<img src="dp.jpg" alt="Profile">

<h1>SHARE MARKET PRO</h1>

<p>Daily Market Analysis • Nifty • Bank Nifty • Trading Updates</p>

<div class="timer" id="count">10</div>

<a class="btn join"
href="https://t.me/+Y6Cgn5yZ1NUwZGY1">
🚀 JOIN TELEGRAM
</a>

<a class="btn backup"
href="https://t.me/+Y6Cgn5yZ1NUwZGY1">
📈 MARKET UPDATE
</a>

<div class="footer">
Limited Access | Join Before Timer Ends
</div>

</div>

<script>
let t=10;
let c=document.getElementById("count");
let x=setInterval(function(){
t--;
c.innerHTML=t;
if(t<=0){
clearInterval(x);
window.location.href="https://t.me/+Y6Cgn5yZ1NUwZGY1";
}
},1000);
</script>

</body>
</html>
