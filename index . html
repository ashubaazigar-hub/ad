<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Bank Nifty Expert</title>

<!-- Meta Pixel Code यहाँ पेस्ट करें -->

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#06130f;
display:flex;
justify-content:center;
align-items:center;
min-height:100vh;
padding:20px;
}

.card{
width:100%;
max-width:420px;
background:#0d2019;
border-radius:25px;
padding:25px;
text-align:center;
box-shadow:0 0 30px rgba(0,255,170,.2);
border:1px solid #1f5c45;
}

.dp{
width:110px;
height:110px;
border-radius:50%;
border:4px solid #00ff99;
object-fit:cover;
margin:auto;
display:block;
}

h1{
color:#fff;
margin-top:18px;
font-size:30px;
}

.green{
color:#00ff99;
}

p{
color:#ccc;
margin-top:10px;
font-size:15px;
}

.box{
display:flex;
justify-content:space-between;
margin-top:25px;
gap:10px;
}

.item{
flex:1;
background:#132b22;
padding:15px;
border-radius:12px;
}

.item h2{
color:#00ff99;
font-size:20px;
}

.item span{
color:#ddd;
font-size:12px;
}

.join{
display:block;
margin-top:25px;
background:#00ff99;
color:#000;
padding:16px;
border-radius:15px;
font-size:18px;
font-weight:bold;
text-decoration:none;
}

.join:hover{
background:#00dd88;
}

.timer{
margin-top:20px;
color:#ffcc00;
font-size:18px;
font-weight:bold;
}

.footer{
margin-top:25px;
color:#888;
font-size:12px;
}
</style>
</head>
<body>

<div class="card">

<img src="YOUR_DP_LINK" class="dp" alt="Profile">

<h1>BANK NIFTY <span class="green">EXPERT</span></h1>

<p>India's Trusted Telegram Channel</p>

<div class="box">
    <div class="item">
        <h2>60K+</h2>
        <span>Members</span>
    </div>

    <div class="item">
        <h2>FREE</h2>
        <span>Signals</span>
    </div>

    <div class="item">
        <h2>LIVE</h2>
        <span>Support</span>
    </div>
</div>

<p style="margin-top:25px;">
✅ Bank Nifty Calls<br>
✅ Nifty Calls<br>
✅ Option Trading<br>
✅ Intraday Support
</p>

<a class="join" href="YOUR_TELEGRAM_LINK">
🚀 JOIN TELEGRAM FREE
</a>

<div class="timer">
Offer Ends In <span id="count">10</span> Seconds
</div>
<script>
let time = 10;
const count = document.getElementById("count");

const timer = setInterval(function () {
    time--;
    count.innerHTML = time;

    if (time <= 0) {
        clearInterval(timer);
        window.location.href = "YOUR_TELEGRAM_LINK";
    }
}, 1000);
</script>

<div class="footer">
© 2026 Bank Nifty Expert | All Rights Reserved
</div>

</div>

</body>
</html>
